# CineButler — secrets only
# Copy to .env and fill in your actual values.
# All other settings (target dirs, actions, notifications, etc.) belong in config.yaml.

# LLM provider (any OpenAI-compatible API)
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=deepseek-chat

# TMDB API key — get one free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key-here

# Optional: TMDB reverse proxy (leave commented out to use the official endpoint)
# TMDB_BASE_URL=https://your-proxy.example.com/tmdb
