# CineButler 环境变量模板
# 复制为 .env 后填写实际值

# LLM 配置
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-your-deepseek-api-key
LLM_MODEL=deepseek-chat

# TMDB API Key (用于刮削识别)
TMDB_API_KEY=your-tmdb-api-key

# TMDB API Base URL（可替换为反代地址，默认官方地址）
# TMDB_BASE_URL=https://api.themoviedb.org/3

# 文件操作模式：cp（复制，默认）或 mv（移动）
# cp：保留下载目录中的原始文件，安全但占用双倍空间
# mv：直接移动，节省空间但原始位置文件消失
FILE_OP_MODE=cp
